# SLACK_BOT_TOKEN = os.environ["SLACK_BOT_TOKEN"]\
SLACK_BOT_TOKEN = "YOUR_BOT_USER_OAUTH_TOKEN"\
\
# Replace with the ID of your Slack channel\
# You can find the channel ID by right-clicking on the channel in Slack\
# and selecting "Copy Link," the ID is the string starting with C or G after the last /\
CHANNEL_ID = "YOUR_CHANNEL_ID"\
\
client = WebClient(token=SLACK_BOT_TOKEN)\
\
def get_channel_messages(channel_id):\
    messages = []\
    try:\
        # Fetch conversations history\
        result = client.conversations_history(channel=channel_id)\
        messages.extend(result["messages"])\
\
        # For large channels, you might need to paginate\
        while result["has_more"]:\
            result = client.conversations_history(\
                channel=channel_id,\
                cursor=result["response_metadata"]["next_cursor"]\
            )\
            messages.extend(result["messages"])\
\
    except SlackApiError as e:\
        print(f"Error fetching conversations: \{e\}")\
    return messages\
\
if __name__ == "__main__":\
